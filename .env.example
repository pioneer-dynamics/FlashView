APP_NAME=FlashView
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_DOMAIN=flashview.link
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

OCTANE_SERVER=frankenphp
OCTANE_HTTPS=false
# OCTANE_WORKERS=4  # Defaults to CPU count when unset; override only if needed
OCTANE_MAX_REQUESTS=500

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_SCHEME=null
MAIL_FROM_ADDRESS="hello@{APP_DOMAIN}"
MAIL_FROM_NAME="${APP_NAME}"

# S3 / MinIO file storage
# For local development with Sail, set FILESYSTEM_DISK=s3 and use the MinIO defaults below.
# MinIO console: http://localhost:8900  (user: sail / password: password)
AWS_ACCESS_KEY_ID=sail
AWS_SECRET_ACCESS_KEY=password
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=local
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

GOOGLE_TAG_MANAGER_ENABLED=false

POSTHOG_PROJECT_TOKEN=
POSTHOG_HOST=
POSTHOG_DISABLED=false

VITE_APP_NAME="${APP_NAME}"
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=
SECRET_PRUNE_AFTER_EXPIRY_DAYS_PLUS=30
NIGHTWATCH_TOKEN=

# Passkey authentication logo (must be a data URI, e.g. data:image/svg+xml;utf8,<svg ...>)
PASSKEY_APP_LOGO=

LARAVEL_CLOUDFLARE_ENABLED=true
LARAVEL_CLOUDFLARE_REPLACE_IP=true
TRUSTED_PROXIES=*

# Non-production access gate: comma-separated list of email addresses permitted to register and subscribe.
# Only active when APP_ENV is not 'production', 'prod', or 'testing'.
ACCESS_ALLOWED_EMAILS=

# Comma-separated list of email addresses with admin access to /admin/plans.
ADMIN_EMAILS=

# Note: eLocker Stripe Price IDs are managed in the Admin panel (Admin → eLocker Plans)
# and stored in the database — no env vars needed.

# TURN server (POC: PHP Artisan TURN Server — see PIO-111)
TURN_HOST=0.0.0.0
TURN_PORT=3478
# Optional: server's public IP for XOR-RELAYED-ADDRESS. Auto-detected on startup if left empty.
# Set explicitly if auto-detection is unreliable in your environment.
TURN_PUBLIC_IP=
TURN_REALM=flashview.io
TURN_USERNAME=flash
# IMPORTANT: change this before any internet-facing deployment
TURN_PASSWORD=changeme
TURN_ALLOCATION_TTL=600
TURN_RELAY_MIN_PORT=49152
TURN_RELAY_MAX_PORT=65535
